# Database (Neon PostgreSQL connection string)
DATABASE_URL="postgres://user:password@host:5432/dbname"

# Upstash Redis (REST API — from Upstash Console)
UPSTASH_REDIS_URL="https://<id>.upstash.io"
UPSTASH_REDIS_TOKEN=""

# Better Auth
BETTER_AUTH_SECRET=""         # Random 32+ char string (generate at randomkeygen.com)
BETTER_AUTH_URL="http://localhost:3000"

# Resend (email sending)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Vercel Cron protection
CRON_SECRET=""                # Random secret — sent as Authorization header by Vercel Cron

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
